<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tugas Pekan 05 - Hosilawati</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        /* CSS Comments: Tema Dark Mode Profesional */

        /* CSS Box Model & Reset */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        }

        /* CSS Colors & Backgrounds */
        body {
            background-color: #0d1117; 
            color: #c9d1d9;
            padding: 50px 20px;
        }

        .main-card {
            max-width: 850px;
            margin: 0 auto;
            background-color: #161b22;
            /* CSS Borders & Outline */
            border: 1px solid #30363d;
            outline: 1px solid #21262d;
            border-radius: 10px;
            padding: 40px;
            /* CSS Height / Width */
            min-height: 550px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        /* CSS Text & Headings */
        h1 {
            color: #58a6ff;
            font-size: 26px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
        }

        .user-info {
            background-color: #0d1117;
            padding: 20px;
            margin-bottom: 30px;
            border-left: 5px solid #238636; /* CSS Borders */
            border-radius: 4px;
        }

        .user-info p {
            font-size: 16px;
            margin: 5px 0;
        }

        /* CSS Lists */
        .list-materi {
            list-style: none;
            margin: 20px 0;
        }

        .list-materi li {
            margin-bottom: 10px;
            color: #8b949e;
            display: flex;
            align-items: center;
        }

        .list-materi li::before {
            content: "→";
            color: #3fb950;
            margin-right: 12px;
            font-weight: bold;
        }

        /* CSS Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 30px;
            background-color: #0d1117;
        }

        th, td {
            border: 1px solid #30363d;
            padding: 15px;
            text-align: left;
        }

        th {
            background-color: #21262d;
            color: #f0f6fc;
            font-weight: 600;
        }

        .status-ok {
            color: #3fb950; /* Hijau Sukses */
            font-weight: bold;
        }

        /* CSS Icons */
        .icon-yellow {
            color: #d29922;
            margin-right: 15px;
        }

        /* CSS Links */
        .footer-link {
            margin-top: 50px;
            text-align: center;
            font-size: 13px;
            color: #8b949e;
        }

        .footer-link a {
            color: #58a6ff;
            text-decoration: none;
        }

        .footer-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="main-card">
        <h1><i class="fas fa-file-alt icon-yellow"></i>Kegiatan Belajar Pekan 05.txt</h1>

        <div class="user-info">
            <p><strong>Nama Lengkap :</strong> Hosilawati</p>
            <p><strong>NIM Terakhir  :</strong> 021</p>
        </div>

        <p>// Ruang Lingkup Materi (CSS Lists):</p>
        <ul class="list-materi">
            <li>CSS Comments & Colors</li>
            <li>CSS Backgrounds, Borders & Outline</li>
            <li>CSS Margins, Padding & Box Model</li>
            <li>CSS Text, Fonts, Icons & Links</li>
            <li>CSS Tables & Height/Width</li>
        </ul>

        <table>
            <thead>
                <tr>
                    <th>Komponen</th>
                    <th>Status Tugas</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Implementasi Layout</td>
                    <td class="status-ok">Success</td>
                </tr>
                <tr>
                    <td>Dark Mode Styling</td>
                    <td class="status-ok">Applied</td>
                </tr>
                <tr>
                    <td>CSS Errors Check</td>
                    <td class="status-ok">No Errors Found</td>
                </tr>
            </tbody>
        </table>

        <div class="footer-link">
            Build with <span style="color: #f85149;">❤</span> by <a href="#">Hosilawati</a> | 2026
        </div>
    </div>

</body>
</html>
